{
  "name": "auraframe",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "rm -rf .next",
    "build": "next build",
    "postbuild": "cp -R .next/static .next/standalone/.next/static && cp .env.local .next/standalone/.env.local && cp .env.production.local .next/standalone/.env.production.local && mkdir -p .next/standalone/scripts && cp scripts/start-standalone.cjs .next/standalone/scripts/start-standalone.cjs",
    "start": "NODE_OPTIONS='--max-old-space-size=384' node scripts/start-standalone.cjs",
    "start:next": "next start -p 8778",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "cdn:migrate:check": "node scripts/migrate-wallpapers-to-cloudinary.mjs",
    "cdn:migrate:apply": "node scripts/migrate-wallpapers-to-cloudinary.mjs --apply"
  },
  "dependencies": {
    "@fontsource/noto-sans-myanmar": "^5.2.7",
    "mysql2": "^3.22.5",
    "next": "16.2.7",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
